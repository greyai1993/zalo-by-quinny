# ─── Supabase ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Zalo OA — ZNS Notifications ────────────────────────────────────────────
# Get from: https://developers.zalo.me → OA → Access Token
# Token expires every 90 days — refresh via OAuth
ZALO_OA_ACCESS_TOKEN=PLACEHOLDER_REPLACE_WITH_REAL_TOKEN

# ZNS Template IDs — Get from oa.zalo.me → ZNS → Template Management
# After templates are approved by Zalo, replace these IDs:
ZALO_ZNS_TEMPLATE_ORDER_CONFIRMED=TEMPLATE_ORDER_CONFIRMED
ZALO_ZNS_TEMPLATE_ORDER_SHIPPING=TEMPLATE_ORDER_SHIPPING
ZALO_ZNS_TEMPLATE_ORDER_DELIVERED=TEMPLATE_ORDER_DELIVERED

# ─── Abit ───────────────────────────────────────────────────────────────────
# From Abit partner portal: https://new.abitstore.vn
ABIT_ACCESS_TOKEN=ZjQ1Y2EyMmJhMDllYzkxMGMzM2JlNGI0ZDU4MGUyOGY=
ABIT_PARTNER_NAME=Quinny

# ─── App Config ─────────────────────────────────────────────────────────────
# Used for self-referential API calls (e.g., triggering Abit sync)
NEXT_PUBLIC_API_URL=https://your-vercel-url.vercel.app

# Cron job security — set a random secret, add to Vercel env
# Vercel Cron automatically sends: Authorization: Bearer {CRON_SECRET}
CRON_SECRET=generate_a_random_secret_here

# ─── CORS ───────────────────────────────────────────────────────────────────
# Set to your Mini App domain or * for development
ALLOWED_ORIGIN=*

# ─── SETUP CHECKLIST ────────────────────────────────────────────────────────
# ⚠️  Before deploying to production:
#
# 1. SUPABASE:
#    - Create project at supabase.com
#    - Run migrations (see /supabase/schema.sql when created)
#    - Copy URL + anon key + service_role key above
#    - Enable RLS on all tables
#
# 2. ZALO OA + ZNS:
#    - Register OA at oa.zalo.me (requires GPKD or CCCD)
#    - Wait 3-7 days for verification
#    - Create ZNS templates (3 templates: confirmed / shipping / delivered)
#    - Wait for Zalo approval (~1-3 days)
#    - Get OA access token from developers.zalo.me
#    - Set ZALO_OA_ACCESS_TOKEN + 3 template IDs above
#    - ⚠️  Token expires every 90 days — set up refresh reminder!
#
# 3. ABIT:
#    - ABIT_ACCESS_TOKEN is already set (from existing integration)
#    - Verify /api/sync/abit works by placing a test order
#    - Check /api/sync/inventory returns products
#
# 4. VERCEL:
#    - vercel.json cron: /api/sync/inventory runs every 15 min
#    - Set CRON_SECRET in Vercel env vars
#    - Cron requires Vercel Pro plan (or use free tier with external cron like cron-job.org)
#
# 5. MINI APP INTEGRATION:
#    - Mini App frontend calls this backend at NEXT_PUBLIC_API_URL
#    - All /api/* endpoints are CORS-enabled
